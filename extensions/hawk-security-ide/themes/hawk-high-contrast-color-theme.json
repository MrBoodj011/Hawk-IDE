{
  "$schema": "vscode://schemas/color-theme",
  "name": "Hawk High Contrast",
  "include": "./hawk-carbon-color-theme.json",
  "type": "hc",
  "semanticHighlighting": true,
  "colors": {
    "contrastActiveBorder": "#FFD166",
    "contrastBorder": "#536D82",
    "focusBorder": "#FFD166",
    "foreground": "#FFFFFF",
    "descriptionForeground": "#C8D4DD",
    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#FFFFFF",
    "activityBar.background": "#000000",
    "activityBar.foreground": "#FFD166",
    "activityBar.inactiveForeground": "#C8D4DD",
    "activityBar.activeBorder": "#FFD166",
    "sideBar.background": "#000000",
    "sideBar.foreground": "#FFFFFF",
    "editorGroupHeader.tabsBackground": "#000000",
    "tab.activeBackground": "#101010",
    "tab.activeForeground": "#FFFFFF",
    "tab.activeBorderTop": "#FFD166",
    "tab.inactiveForeground": "#C8D4DD",
    "editor.background": "#000000",
    "editor.foreground": "#FFFFFF",
    "editorCursor.foreground": "#FFD166",
    "editorLineNumber.foreground": "#9DB0BE",
    "editorLineNumber.activeForeground": "#FFD166",
    "editor.selectionBackground": "#165C70",
    "panel.background": "#000000",
    "panelTitle.activeForeground": "#FFFFFF",
    "panelTitle.activeBorder": "#FFD166",
    "terminal.background": "#000000",
    "terminal.foreground": "#FFFFFF",
    "terminalCursor.foreground": "#FFD166",
    "statusBar.background": "#000000",
    "statusBar.foreground": "#FFFFFF",
    "input.background": "#000000",
    "input.foreground": "#FFFFFF",
    "input.border": "#9DB0BE",
    "button.background": "#FFD166",
    "button.foreground": "#000000",
    "button.hoverBackground": "#FFE6A3",
    "list.activeSelectionBackground": "#233C4A",
    "list.activeSelectionForeground": "#FFFFFF",
    "quickInput.background": "#000000",
    "quickInput.foreground": "#FFFFFF"
  }
}
