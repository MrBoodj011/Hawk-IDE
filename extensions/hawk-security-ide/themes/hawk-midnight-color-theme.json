{
  "$schema": "vscode://schemas/color-theme",
  "name": "Hawk Midnight",
  "include": "./hawk-carbon-color-theme.json",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "focusBorder": "#57D7FF99",
    "titleBar.activeBackground": "#020712",
    "titleBar.inactiveBackground": "#020712",
    "activityBar.background": "#020712",
    "activityBar.foreground": "#57D7FF",
    "activityBar.activeBorder": "#57D7FF",
    "sideBar.background": "#050B17",
    "editorGroupHeader.tabsBackground": "#020712",
    "tab.activeBackground": "#081324",
    "tab.activeBorderTop": "#57D7FF",
    "editor.background": "#040914",
    "editorCursor.foreground": "#57D7FF",
    "editor.selectionBackground": "#57D7FF22",
    "panel.background": "#050B17",
    "panelTitle.activeBorder": "#57D7FF",
    "terminal.background": "#020712",
    "terminalCursor.foreground": "#57D7FF",
    "statusBar.background": "#07101E",
    "button.background": "#57D7FF",
    "button.foreground": "#020712",
    "button.hoverBackground": "#8BE6FF",
    "badge.background": "#57D7FF",
