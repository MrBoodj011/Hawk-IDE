    "welcomePage.progress.foreground": "#F5C15B",
    "walkThrough.embeddedEditorBackground": "#0D1015"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#59636B", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#A8E6A3" }
    },
    {
      "scope": ["constant.numeric", "constant.language", "constant.character"],
      "settings": { "foreground": "#FFC978" }
    },
    {
      "scope": ["keyword", "storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#F5C15B" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": { "foreground": "#52DED4" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.class", "support.type"],
      "settings": { "foreground": "#FFD274" }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": { "foreground": "#D7DCDE" }
    },
    {
      "scope": ["variable.other.property", "meta.object-literal.key", "support.variable.property"],
      "settings": { "foreground": "#B8C9FF" }
    },
    {
      "scope": ["entity.name.tag", "meta.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#FF7B5C" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#F5C15B" }
    },
    {
      "scope": ["keyword.operator", "punctuation.accessor", "punctuation.separator"],
      "settings": { "foreground": "#8C969D" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#FFFFFF", "background": "#FF4D6D88" }
    },
    {
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#F5C15B", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#F5F7F4", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "foreground": "#C5CCD0", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inserted", "markup.changed"],
      "settings": { "foreground": "#65D9A6" }
    },
    {
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#FF5A74" }
    }
  ]
}
