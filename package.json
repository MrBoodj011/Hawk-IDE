{
  "name": "@pentesterflow/ide",
  "version": "0.1.0-dev",
  "description": "Security-native AI development environment for evidence-driven code review and authorized pentesting.",
  "type": "module",
  "workspaces": [
    "extensions/*"
  ],
  "bin": {
    "pentesterflow": "./dist/cli.js",
    "pentesterflow-browser-mcp": "./dist/browser-mcp.js",
    "pentesterflow-ide-daemon": "./dist/ide-daemon.js",
    "pentesterflow-ide-mcp": "./dist/ide-mcp.js"
  },
  "files": [
    "dist",
    "skills",
    "docs",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "dev:burp": "tsx src/cli/index.ts --burp",
    "dev:ide-daemon": "tsx src/ide/daemonCli.ts",
    "build:extension": "npm --workspace pentesterflow-ide run build",
    "check:extension": "npm --workspace pentesterflow-ide run check",
    "package:extension": "npm --workspace pentesterflow-ide run package",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build && npm run check:extension && npm run build:extension"
  },
  "keywords": [
    "pentest",
    "bug-bounty",
    "security",
    "cli",
    "agent",
    "llm",
    "ollama",
    "mcp",
    "offensive-security",
    "red-team",
    "ide",
    "appsec",
    "security-review"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/MrBoodj011/pentesterflow-ide",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrBoodj011/pentesterflow-ide.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "execa": "^9.5.1",
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "marked": "^14.1.4",
    "marked-terminal": "^7.2.1",
    "pino": "^9.5.0",
    "react": "^18.3.1",
    "undici": "^6.21.0",
    "write-file-atomic": "^6.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/write-file-atomic": "^4.0.3",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^4.28.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
